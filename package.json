{
  "name": "marrakech-dunes",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "dependencies": {
    "@replit/vite-plugin-cartographer": "^0.2.7",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
    "@tailwindcss/typography": "^0.5.16",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.3.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "dev": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build:client": "npm --workspace client run build",
    "build:server": "npm --workspace server run build",
    "copy-client-build": "copyfiles -u 2 client/dist/**/* server/src/public",
    "build": "npm run build:client && npm run copy-client-build && npm run build:server",
    "start": "npm --workspace server start",
    "cleanup:assets": "node scripts/delete-unused-images.js"
  }
}
