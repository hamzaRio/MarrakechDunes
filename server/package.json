    "bcrypt": "^6.0.0",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.16.1",
    "nanoid": "^5.1.5",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "esbuild": "^0.25.0",
