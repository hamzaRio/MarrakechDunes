{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "outDir": "./dist",
    "rootDirs": ["./src", "../shared"],         // ✅ Multiple roots (avoids TS6059)
    "paths": {
      "@shared/*": ["../shared/*"]              // ✅ Match actual structure
    }
  },
  "include": [
    "src/**/*",
    "../shared/**/*"                            // ✅ Correct include for shared code
  ],
  "exclude": ["node_modules", "dist"]
}
