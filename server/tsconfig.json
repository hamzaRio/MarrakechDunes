{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "outDir": "./dist",
    "rootDir": ".",                          // ✅ Must include `../shared`
    "paths": {
      "@shared/*": ["../shared/*"]
    },
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "../shared/**/*"],  // ✅ explicitly include shared
  "exclude": ["node_modules", "dist"]
}
